# BatchKit — Environment Variables
# Copy to .env.local and fill in your values.
# Get these from: https://supabase.com/dashboard/project/<your-project>/settings/api

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — server-side only, NEVER expose to client
# Used for admin operations and invite sending
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# App URL — used for invite and auth callback links
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google OAuth — get from Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
# Set Authorized redirect URI to: https://<your-project>.supabase.co/auth/v1/callback
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=your-google-client-id
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=your-google-client-secret
